{
  "name": "afosto/yaac",
  "description": "Yet Another ACME client: a decoupled LetsEncrypt client",
  "type": "package",
  "keywords": [
    "afosto",
    "lets",
    "acme",
    "acmev2",
    "v2",
    "encrypt",
    "letsencrypt"
  ],
  "homepage": "https://github.com/afosto/yaac",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Afosto Team",
      "homepage": "https://afosto.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Afosto\\Acme\\": "./src"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-openssl": "*",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.0",
    "league/flysystem": "^3.0"
  },
  "require-dev": {
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "phpstan/phpstan": "^2.2",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "scripts": {
    "analyse": [
      "phpstan analyse --memory-limit 2G --level 5 src"
    ],
    "lint": [
      "parallel-lint --exclude vendor ."
    ],
    "sniff": [
      "phpcs --standard=PSR12 src/"
    ],
    "test": [
      "@sniff",
      "@lint",
      "@analyse"
    ]
  },
  "config": {
    "sort-packages": true
  }
}
